# Binance (optionnel pour donnees publiques)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_LOOP_SUMMARY=false
TELEGRAM_ENABLE_COMMANDS=true
TELEGRAM_POLL_INTERVAL_SECONDS=1
TELEGRAM_LONG_POLL_TIMEOUT_SECONDS=25
TELEGRAM_HTTP_TIMEOUT_SECONDS=35
TELEGRAM_POLL_ERROR_BACKOFF_SECONDS=10

# Trading global fallback (si un symbole n'est dans aucun groupe)
TIMEFRAME=30m
LOOP_INTERVAL_SECONDS=1800
INITIAL_CAPITAL_USDT=100.0
TRADE_ALLOCATION=0.20
OHLCV_LIMIT=200

# RSI / MACD global fallback
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
MACD_FAST=8
MACD_SLOW=26
MACD_SIGNAL=9

# Risk global fallback
ENABLE_STOPS=true
STOP_LOSS_PCT=-3.0
TAKE_PROFIT_PCT=6.0
TAKER_FEE_PCT=0.1
SLIPPAGE_PCT=0.05

# --- Groupes strategie (majors vs alts volatiles) ---
# Note: le mapping groupe/symboles est actuellement defini dans config.py.
# Ce bloc sert de reference de parametrage pour les profils.

# MAJORS: BTC, ETH, BNB
GROUP_MAJORS_TIMEFRAME=1h
GROUP_MAJORS_RSI_PERIOD=14
GROUP_MAJORS_RSI_OVERSOLD=36
GROUP_MAJORS_RSI_OVERBOUGHT=67
GROUP_MAJORS_MACD_FAST=8
GROUP_MAJORS_MACD_SLOW=26
GROUP_MAJORS_MACD_SIGNAL=9
GROUP_MAJORS_TRADE_ALLOCATION=0.20
GROUP_MAJORS_STOP_LOSS_PCT=-4.0
GROUP_MAJORS_TAKE_PROFIT_PCT=8.0

# ALTS VOLATILES: ADA, XRP, DOGE, MATIC
GROUP_ALTS_TIMEFRAME=30m
GROUP_ALTS_RSI_PERIOD=14
GROUP_ALTS_RSI_OVERSOLD=34
GROUP_ALTS_RSI_OVERBOUGHT=64
GROUP_ALTS_MACD_FAST=8
GROUP_ALTS_MACD_SLOW=26
GROUP_ALTS_MACD_SIGNAL=9
GROUP_ALTS_TRADE_ALLOCATION=0.12
GROUP_ALTS_STOP_LOSS_PCT=-2.5
GROUP_ALTS_TAKE_PROFIT_PCT=5.5

# Persistance
DATA_DIR=data
MAX_STORED_TRADES=2000
MAX_STORED_SNAPSHOTS=3000

# API mobile
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN=change_me
LOCAL_TIMEZONE=Europe/Paris

# Docker production limits
BOT_CPU_LIMIT=1.50
BOT_MEM_LIMIT=1024m
BOT_MEM_RESERVATION=512m
TZ=Europe/Paris
